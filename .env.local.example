# Copy to .env.local and fill in. Never commit real values.

# Supabase (publishable key is safe to expose to the browser; used by the
# SSR client helpers in src/utils/supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Resend (owner notification + customer confirmation emails) — server-only
RESEND_API_KEY=
OWNER_ORDER_EMAIL=orders@smalltownsipsnutrition.com
FROM_EMAIL=orders@smalltownsipsnutrition.com
